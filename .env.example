# PostgreSQL Database Connection
# Format: postgresql://user:password@host:port/database
# Note: Special characters in password must be URL-encoded (@ = %40, ! = %21)
DB_URL=postgresql://admin:password@localhost:5432/postgres

# Google Gemini API Key (from Google AI Studio)
GOOGLE_API_KEY=your_gemini_api_key_here

# Optional: Table name prefix for generated tables (default: api_)
TABLE_PREFIX=api_

# Optional: Schema to use (default: public)
DB_SCHEMA=public
